# Copy to .env — docker compose reads it automatically.

# --- Google SSO (required for signup/login) ---
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
# → Application type: Web application
# → Authorized JavaScript origins: http://localhost:5173
# Paste the Client ID here (it's a public value).
GOOGLE_CLIENT_ID=

# Optional: fixed secret for signing sessions. If empty, one is generated and
# persisted so logins survive restarts.
SESSION_SECRET=

# --- AI Coach (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Strava ---
# Strava keys are now entered PER USER during onboarding (not here).
# These only control the OAuth redirect target — defaults are fine for local Docker.
STRAVA_REDIRECT_URI=http://localhost:8080/api/strava/callback
FRONTEND_URL=http://localhost:5173
